<div class="w-full max-w-2xl mx-auto flex flex-col gap-4 pb-16">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm mb-1">
    <a href="/" class="font-semibold text-gray-700 hover:text-gray-900 transition-colors">Meu Perfil</a>
    <svg class="w-4 h-4 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
    <span class="text-gray-400">Editar Perfil</span>
  </nav>

  <!-- Avatar -->
  <div class="flex justify-center my-4">
    <div class="relative">
      <img id="avatar-img" src="<%= userFoto %>" class="w-24 h-24 rounded-full object-cover bg-gray-100 shadow-md" alt="<%= userNome %>" />
      <div id="avatar-spinner" class="hidden absolute inset-0 rounded-full bg-black/40 flex items-center justify-center">
        <svg class="w-8 h-8 text-white animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.2-8.56" /></svg>
      </div>
      <button type="button" id="avatar-botao" title="Alterar foto"
        class="absolute -bottom-1 -right-1 w-9 h-9 rounded-full bg-green-600 hover:bg-green-700 text-white flex items-center justify-center shadow-md transition-colors cursor-pointer">
        <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3Z" /><circle cx="12" cy="13" r="3" /></svg>
      </button>
      <input type="file" id="avatar-input" accept="image/png,image/jpeg,image/webp" class="hidden" />
    </div>
  </div>

  <!-- Cargo -->
   
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-center justify-between">
    <div class="flex items-center gap-3 text-gray-700 font-medium">
      <svg class="w-5 h-5 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2" /><circle cx="12" cy="10" r="2.5" /><path d="M7 16.5c1-1.6 2.7-2.5 5-2.5s4 .9 5 2.5" /></svg>
      Cargo
    </div>
    <% if (typeof cargos !== 'undefined' && cargos) { %>
    <select id="cargo-select" class="border border-gray-200 rounded-lg pl-3 pr-2 py-2 text-sm text-gray-700 bg-white outline-none focus:ring-2 focus:ring-green-500 cursor-pointer">
      <% cargos.forEach(function (c) { %>
      <option value="<%= c.id %>" <%= userGrupo == c.id ? 'selected' : '' %>><%= c.name.charAt(0).toUpperCase() + c.name.slice(1) %></option>
      <% }); %>
    </select>
    <% } else { %>
    <div class="flex items-center gap-1.5 border border-gray-200 rounded-lg pl-4 pr-3 py-2 text-sm text-gray-700 bg-white">
      <%= userCargo %>
    </div>
    <% } %>
  </div>

  <!-- Permissões de Acesso -->
   <% if (userGrupo == 5) { %>
    <p class="text-sm text-gray-500 mt-2 px-1">Permissões de Acesso</p>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-5 divide-y divide-gray-100">
      <% if (typeof permissoes !== 'undefined' && permissoes) { %>
      <%# Catálogo gerenciável: toggles funcionais (mesmas regras da tela de equipe do SSO) %>
      <% permissoes.forEach(function (perm) { %>
      <div class="flex items-center justify-between py-4">
        <span class="text-sm <%= perm.granted ? 'text-green-800' : 'text-gray-700' %>"><%= perm.name %></span>
        <button type="button" role="switch" aria-checked="<%= perm.granted %>" data-permissao="<%= perm.name %>"
          class="toggle-permissao relative inline-flex h-6 w-11 items-center rounded-full transition-colors shrink-0 cursor-pointer <%= perm.granted ? 'bg-green-500' : 'bg-gray-300' %>">
          <span class="inline-block h-4 w-4 transform rounded-full bg-white shadow transition-transform <%= perm.granted ? 'translate-x-6' : 'translate-x-1' %>"></span>
        </button>
      </div>
      <% }); %>
      <% } else { %>
      <%# Sem permissão de gerenciar: exibe só as permissões atuais, somente leitura %>
      <% (user && user.permissions ? user.permissions : []).forEach(function (perm) { %>
      <div class="flex items-center justify-between py-4">
        <span class="text-sm text-gray-700"><%= perm.name %></span>
        <span class="relative inline-flex h-6 w-11 items-center rounded-full bg-green-500 shrink-0 opacity-90" title="Permissão gerenciada pelo administrador">
          <span class="inline-block h-4 w-4 translate-x-6 transform rounded-full bg-white shadow"></span>
        </span>
      </div>
      <% }); %>
      <% if (!user || !user.permissions || user.permissions.length === 0) { %>
      <p class="py-4 text-sm text-gray-400">Nenhuma permissão atribuída.</p>
      <% } %>
      <% } %>
    </div>
  <% } %>

  <!-- Dados do perfil -->
  <form id="perfil-form" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex flex-col gap-4 mt-2">
    <div>
      <label for="campo-name" class="block text-xs text-gray-500 mb-1">Nome Completo</label>
      <input id="campo-name" name="name" type="text" value="<%= user ? user.name : '' %>" required minlength="2" maxlength="80"
        class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 outline-none focus:ring-2 focus:ring-green-500 focus:bg-white transition-all" />
      <p class="campo-erro hidden text-xs text-red-600 mt-1" data-field="name"></p>
    </div>

    <div>
      <label for="campo-email" class="block text-xs text-gray-500 mb-1">Email</label>
      <input id="campo-email" name="email" type="email" value="<%= user ? user.email : '' %>"
        class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 outline-none focus:ring-2 focus:ring-green-500 focus:bg-white transition-all" />
      <p class="campo-erro hidden text-xs text-red-600 mt-1" data-field="email"></p>
    </div>

    <div>
      <label for="campo-telefone" class="block text-xs text-gray-500 mb-1">Telefone</label>
      <input id="campo-telefone" name="telefone" type="tel" maxlength="15" value="<%= user && user.telefone ? user.telefone : '' %>"
        class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 outline-none focus:ring-2 focus:ring-green-500 focus:bg-white transition-all" />
      <p class="campo-erro hidden text-xs text-red-600 mt-1" data-field="telefone"></p>
    </div>

    <div>
      <label for="campo-cpf" class="block text-xs text-gray-500 mb-1">CPF</label>
      <input id="campo-cpf" name="cpf" type="text" maxlength="14" value="<%= user && user.cpf ? user.cpf : '' %>"
        class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 outline-none focus:ring-2 focus:ring-green-500 focus:bg-white transition-all" />
      <p class="campo-erro hidden text-xs text-red-600 mt-1" data-field="cpf"></p>
    </div>

    <div>
      <label for="campo-data" class="block text-xs text-gray-500 mb-1">Data de Nascimento</label>
      <input id="campo-data" name="data_nascimento" type="date" value="<%= user && user.data_nascimento ? user.data_nascimento : '' %>"
        class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-800 outline-none focus:ring-2 focus:ring-green-500 focus:bg-white transition-all" />
      <p class="campo-erro hidden text-xs text-red-600 mt-1" data-field="data_nascimento"></p>
    </div>
  </form>

  <button id="btn-salvar" form="perfil-form" type="submit"
    class="w-full bg-green-600 hover:bg-green-700 disabled:opacity-60 disabled:cursor-not-allowed text-white font-semibold rounded-xl py-3 transition-colors cursor-pointer">
    Atualizar Perfil
  </button>

  <!-- Toast -->
  <div id="toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 px-5 py-3 rounded-full text-sm font-medium text-white shadow-lg z-50"></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('perfil-form');
    const btn = document.getElementById('btn-salvar');
    const toast = document.getElementById('toast');

    function showToast(message, ok) {
      toast.textContent = message;
      toast.classList.remove('hidden', 'bg-green-600', 'bg-red-600');
      toast.classList.add(ok ? 'bg-green-600' : 'bg-red-600');
      setTimeout(() => toast.classList.add('hidden'), 4000);
    }

    function clearFieldErrors() {
      document.querySelectorAll('.campo-erro').forEach(el => {
        el.classList.add('hidden');
        el.textContent = '';
      });
    }

    function showFieldErrors(fields) {
      Object.entries(fields || {}).forEach(([name, msg]) => {
        const el = document.querySelector(`.campo-erro[data-field="${name}"]`);
        if (el) {
          el.textContent = Array.isArray(msg) ? msg[0] : msg;
          el.classList.remove('hidden');
        }
      });
    }

    // ---------- Toggles de permissão ----------
    document.querySelectorAll('.toggle-permissao').forEach(function (toggle) {
      toggle.addEventListener('click', async function () {
        toggle.disabled = true;
        try {
          const res = await fetch('/api/v1/users/me/permissions/toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ permission: toggle.dataset.permissao }),
          });
          const body = await res.json().catch(() => null);

          if (res.ok && body && typeof body.status === 'boolean') {
            const ligada = body.status;
            toggle.setAttribute('aria-checked', String(ligada));
            toggle.classList.toggle('bg-green-500', ligada);
            toggle.classList.toggle('bg-gray-300', !ligada);
            const bolinha = toggle.querySelector('span');
            bolinha.classList.toggle('translate-x-6', ligada);
            bolinha.classList.toggle('translate-x-1', !ligada);
            showToast(toggle.dataset.permissao + (ligada ? ' ativada' : ' desativada'), true);
          } else {
            const error = body && body.error ? body.error : {};
            showToast(error.message || 'Erro ao alterar a permissão.', false);
          }
        } catch (err) {
          showToast('Falha de conexão. Tente novamente.', false);
        } finally {
          toggle.disabled = false;
        }
      });
    });

    // ---------- Seletor de cargo ----------
    const cargoSelect = document.getElementById('cargo-select');
    if (cargoSelect) {
      cargoSelect.dataset.anterior = cargoSelect.value;
      cargoSelect.addEventListener('change', async function () {
        const anterior = cargoSelect.dataset.anterior;
        cargoSelect.disabled = true;
        try {
          const res = await fetch('/api/v1/users/me/cargo', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ role_id: Number(cargoSelect.value) }),
          });
          const body = await res.json().catch(() => null);
          if (res.ok) {
            cargoSelect.dataset.anterior = cargoSelect.value;
            showToast((body && body.message) || 'Cargo atualizado!', true);
            setTimeout(() => window.location.reload(), 800);
          } else {
            cargoSelect.value = anterior;
            showToast((body && body.error && body.error.message) || 'Erro ao trocar de cargo.', false);
          }
        } catch (err) {
          cargoSelect.value = anterior;
          showToast('Falha de conexão. Tente novamente.', false);
        } finally {
          cargoSelect.disabled = false;
        }
      });
    }

    // ---------- Upload de foto de perfil ----------
    const avatarImg = document.getElementById('avatar-img');
    const avatarInput = document.getElementById('avatar-input');
    const avatarSpinner = document.getElementById('avatar-spinner');

    document.getElementById('avatar-botao').addEventListener('click', () => avatarInput.click());

    avatarInput.addEventListener('change', async function () {
      const file = avatarInput.files[0];
      if (!file) return;

      if (file.size > 5 * 1024 * 1024) {
        showToast('Envie uma imagem de até 5MB.', false);
        avatarInput.value = '';
        return;
      }

      const fotoAnterior = avatarImg.src;
      avatarImg.src = URL.createObjectURL(file); // preview otimista
      avatarSpinner.classList.remove('hidden');

      const formData = new FormData();
      formData.append('avatar', file);

      try {
        const res = await fetch('/api/v1/users/me/avatar', { method: 'POST', body: formData });
        const body = await res.json().catch(() => null);

        if (res.ok && body && body.avatarUrl) {
          avatarImg.src = body.avatarUrl;
          showToast('Foto atualizada com sucesso!', true);
        } else {
          avatarImg.src = fotoAnterior; // rollback
          const error = body && body.error ? body.error : {};
          showToast(error.message || 'Erro ao atualizar a foto.', false);
        }
      } catch (err) {
        avatarImg.src = fotoAnterior;
        showToast('Falha de conexão. Tente novamente.', false);
      } finally {
        avatarSpinner.classList.add('hidden');
        avatarInput.value = '';
      }
    });

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      clearFieldErrors();

      const data = {
        name: form.name.value.trim(),
        email: form.email.value.trim(),
        telefone: form.telefone.value.trim(),
        cpf: form.cpf.value.trim(),
        data_nascimento: form.data_nascimento.value || null,
      };

      btn.disabled = true;
      btn.textContent = 'Salvando...';

      try {
        const res = await fetch('/api/v1/users/me', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          showToast('Perfil atualizado com sucesso!', true);
        } else {
          const body = await res.json().catch(() => null);
          const error = body && body.error ? body.error : {};
          showFieldErrors(error.fields);
          showToast(error.message || 'Erro ao atualizar o perfil.', false);
        }
      } catch (err) {
        showToast('Falha de conexão. Tente novamente.', false);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Atualizar Perfil';
      }
    });
  });
</script>
