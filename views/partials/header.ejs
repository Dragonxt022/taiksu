<div id="header-container" class="fixed top-5 px-4 w-full flex items-center justify-center z-50">
    <header id="header" class="rounded-full w-full border border-white/10 max-w-4xl flex items-center justify-between p-4 bg-white/80 backdrop-blur-sm shadow-xs">

        <a id="logo" href="/"><img src="/images/logo/logo.png" class="h-8 p-1.5"></a>
        

        <div class="flex items-center gap-4">
            <% if (userGrupo == 5) { %>
            <a class="w-8 h-8 p-1 bg-gray-100 hover:bg-gray-200 transition-colors duration-200 rounded-full" href="https://login.taiksu.com.br/?redirect_uri=https%3A%2F%2Fdev.taiksu.com.br%2Fcallback">
                <img id="config-icone" src="https://caixa.taiksu.com.br/images/icons/config.png" class="brightness-90 transition-all duration-700" />
            </a>
            <% } %>
            
            <a href="https://login.taiksu.com.br/perfil">
                <img src="<%= userFoto %>" class="w-8 h-8 rounded-full group-hover:scale-105 group-hover:shadow-md transition-all duration-700" />
            </a>

            <a class="w-8 h-8 p-1 bg-gray-100 hover:bg-gray-200 transition-colors duration-200 rounded-full" href="https://alertas.taiksu.com.br/callback?token=<%= userToken %>">
                <img id="alerta-icone" src="/images/icons/aviso0.png" class="brightness-90 transition-all duration-700" />
            </a>

            <button id="logout" class="group flex flex-row items-center justify-center font-medium text-red-700 cursor-pointer hover:text-red-700 bg-red-100 hover:bg-red-200 transition-colors duration-200 rounded-full w-8 h-8 pl-1.5 pr-1 py-1.5" type="submit" id="logout">
                <img src="/images/icons/logout-red.png" class="">
            </button>
        </div>
    </header>
</div>

    <script>
        document.addEventListener("DOMContentLoaded", async () => {

            const userId = <%= user_id %>;
            const url = `https://alertas.taiksu.com.br/api/status/${userId}`;
            const logoutButton = document.getElementById("logout");

            logoutButton.addEventListener("click", async () => {
                const response = await fetch("https://login.taiksu.com.br/api/logout", {
                    method: "POST",
                    headers: {
                        "Authorization": "Bearer <%= userToken %>"
                    }
                });
                if (response.status == 200) {
                    window.location.href = "https://login.taiksu.com.br";
                }
            });

            try {
                const response = await fetch(url, {
                    method: "GET",
                    headers: {
                        "Accept": "application/json",
                    },
                });
                const data = await response.json();

                const icone = document.getElementById("alerta-icone");

                if (data.status === true) {
                    icone.src = "/images/icons/aviso1.png";
                } else {
                    icone.src = "/images/icons/aviso0.png";
                }
            } catch (e) {
                console.error("Erro ao consultar status:", e);
            }
        });
    </script>